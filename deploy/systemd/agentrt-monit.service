# P1.23.2: daemon 启动顺序编排

# ============================================================
# monit_d — 监控守护进程 (Layer 0, 无依赖)
# ============================================================
[Unit]
Description=AgentRT Monitor Daemon
After=network.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=@CMAKE_INSTALL_PREFIX@/bin/monit_d
Restart=on-failure
RestartSec=5
LimitNOFILE=65536

# 安全加固
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ReadWritePaths=@AGENTOS_RUNTIME_DIR@

# 资源限制
LimitNPROC=512

[Install]
WantedBy=multi-user.target
