# P1.23.2: daemon 启动顺序编排

[Unit]
Description=AgentRT Info Daemon
After=network.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=@CMAKE_INSTALL_PREFIX@/bin/info_d
Restart=on-failure
RestartSec=5
LimitNOFILE=65536

NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ReadWritePaths=@AGENTOS_RUNTIME_DIR@
LimitNPROC=512

[Install]
WantedBy=multi-user.target
