# AgentRT Gateway Docker 环境变量配置
# 使用说明:
# 1. 复制此文件为 .env
# 2. 根据实际情况修改配置值（生成随机密钥: openssl rand -hex 32）
# 3. docker-compose 会自动加载此文件

# ==================== 安全密钥配置 ====================

# JWT 密钥（用于 API 认证和 Token 签发）
JWT_SECRET=change-this-to-a-random-secret-key

# PostgreSQL 数据库密码
POSTGRES_PASSWORD=change-this-to-a-random-password

# Grafana 管理员密码
GRAFANA_PASSWORD=change-this-to-a-random-password

# ==================== 数据库配置 ====================

# PostgreSQL 用户
POSTGRES_USER=agentos

# PostgreSQL 数据库名
POSTGRES_DB=agentos

# ==================== 第三方 API 密钥 ====================

# OpenAI API 密钥
OPENAI_API_KEY=sk-your-openai-api-key

# ==================== 其他配置 ====================

# 时区
TZ=Asia/Shanghai
