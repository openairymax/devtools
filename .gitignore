# ===========================================================================
# Airymax DevTools 顶层仓 .gitignore
# 策略：非必要不追踪
# ---------------------------------------------------------------------------
# 默认忽略所有
# ---------------------------------------------------------------------------
*
# ---------------------------------------------------------------------------
# 顶层仓必要文件（白名单）
# ---------------------------------------------------------------------------
!.gitignore
!LICENSE
!NOTICE
!README.md
!README_zh.md
!.clang-format
!.clang-tidy
!.clangd
!.git-blame-ignore-revs
!.pre-commit-config.yaml
!pyproject.toml
!vcpkg.json
!deploy/
!deploy/**
!scripts/
!scripts/**
!tests/
!tests/**
