# =============================================================================
# Airymax DevTools — .gitignore
# =============================================================================

# IDE 配置
.vscode/
.idea/
.vs/
*.code-workspace
.cache/

# 构建目录
build/
build-*/

# Python 缓存
__pycache__/
*.py[cod]

# 环境与密钥
.env
.env.*
!.env.example

# 操作系统
.DS_Store
Thumbs.db

# 编辑器临时文件
*.swp
*.swo
*~
*.log
*.tmp
*.bak
