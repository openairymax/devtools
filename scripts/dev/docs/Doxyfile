OUTPUT_DIRECTORY       = docs/api

CREATE_SUBDIRS         = YES

OUTPUT_LANGUAGE        = Chinese

ABBREVIATE_BRIEF       = "The $name class" \
                         "The $name widget" \
                         "The $name file" \
                         is \
                         provides \
                         specifies \
                         contains \
                         represents \
                         a \
                         an \
                         the

ALWAYS_DETAILED_SEC    = YES

FULL_PATH_NAMES        = YES

STRIP_FROM_PATH        = agentrt

STRIP_FROM_INC_PATH    = agentrt

#---------------------------------------------------------------------------
