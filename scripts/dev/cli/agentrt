def main():
    parser = argparse.ArgumentParser(
        prog="agentrt",
        description="AgentOS Unified CLI - 统一命令行工具"
    )
    subparsers = parser.add_subparsers(dest="command", help="Available commands")

    # Service commands
    svc_parser = subparsers.add_parser("service", help="Service management")
    svc_sub = svc_parser.add_subparsers(dest="subcommand")
    svc_sub.add_parser("list", help="List services")
    svc_sub.add_parser("health", help="Health check")
    svc_sub.add_parser("start", help="Start services")
    svc_sub.add_parser("stop", help="Stop services")
    svc_sub.add_parser("restart", help="Restart services")

    # Agent commands
    agent_parser = subparsers.add_parser("agent", help="Agent management")
    agent_sub = agent_parser.add_subparsers(dest="subcommand")
    agent_sub.add_parser("list", help="List agents")
    agent_sub.add_parser("register", help="Register agent")

    # Task commands
    task_parser = subparsers.add_parser("task", help="Task management")
    task_sub = task_parser.add_subparsers(dest="subcommand")
    task_sub.add_parser("list", help="List tasks")
    task_sub.add_parser("submit", help="Submit task")

    # Protocol commands
    proto_parser = subparsers.add_parser("protocol", help="Protocol operations")
    proto_sub = proto_parser.add_subparsers(dest="subcommand")
    proto_sub.add_parser("list", help="List all protocol adapters")

    proto_info = proto_sub.add_parser("info", help="Show detailed protocol information")
    proto_info.add_argument("proto", help="Protocol name (jsonrpc/mcp/a2a/openai/openjiuwen)")

    proto_test = proto_sub.add_parser("test", help="Test protocol connectivity")
    proto_test.add_argument("proto", help="Protocol name (jsonrpc/mcp/a2a/openai/openjiuwen)")
    proto_test.add_argument("-v", "--verbose", action="store_true", help="Show raw response")

    proto_detect = proto_sub.add_parser("detect", help="Detect protocol from input content")
    proto_detect.add_argument("--content", "-c", default=None, help="JSON content string to analyze")
    proto_detect.add_argument("--content-type", "-t", default=None, help="MIME content-type hint")

    proto_send = proto_sub.add_parser("send", help="Send a protocol message")
    proto_send.add_argument("proto", help="Target protocol (jsonrpc/mcp/a2a/openai)")
    proto_send.add_argument("method", help="Method name or endpoint path")
    proto_send.add_argument("params", nargs="?", default=None, help="JSON params string")

    proto_sub.add_parser("stats", help="Show protocol statistics")

    proto_transform = proto_sub.add_parser("transform", help="Transform between protocols")
    proto_transform.add_argument("src", help="Source protocol")
    proto_transform.add_argument("tgt", help="Target protocol")
    proto_transform.add_argument("data", nargs="?", default=None, help="Optional input data for transformation demo")

    proto_caps = proto_sub.add_parser("capabilities", help="Show protocol capabilities")
    proto_caps.add_argument("proto", help="Protocol name")

    # Config commands
    cfg_parser = subparsers.add_parser("config", help="Configuration management")
    cfg_sub = cfg_parser.add_subparsers(dest="subcommand")
    cfg_get = cfg_sub.add_parser("get", help="Get config value")
    cfg_get.add_argument("key", help="Config key")
    cfg_set = cfg_sub.add_parser("set", help="Set config value")
    cfg_set.add_argument("key", help="Config key")
    cfg_set.add_argument("value", help="Config value")

    # Dev commands
    dev_parser = subparsers.add_parser("dev", help="Development tools")
    dev_sub = dev_parser.add_subparsers(dest="subcommand")
    dev_sub.add_parser("doctor", help="Run diagnostics")
    dev_sub.add_parser("build", help="Build project")
    dev_sub.add_parser("test", help="Run tests")

    # System commands
    subparsers.add_parser("version", help="Show version")
    subparsers.add_parser("status", help="Show system status")

    # Database commands (P3.20.4)
    db_parser = subparsers.add_parser("db", help="Database operations")
    db_sub = db_parser.add_subparsers(dest="subcommand")
    db_migrate = db_sub.add_parser("migrate", help="Run schema migration")
    db_migrate.add_argument("--target", default="v2", help="Target version (default: v2)")
    db_sub.add_parser("migrate-status", help="Show migration status")
    db_migrate_rb = db_sub.add_parser("migrate-rollback", help="Rollback schema migration")
    db_migrate_rb.add_argument("--force", action="store_true", help="Confirm rollback")
    db_sub.add_parser("backup", help="Create data backup")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        return 0

    cmd_map = {
        "service": {
            "list": cmd_service_list,
            "health": cmd_service_health,
        },
        "agent": {
            "list": cmd_agent_list,
        },
        "task": {
            "list": cmd_task_list,
        },
        "protocol": {
            "list": cmd_protocol_list,
            "info": cmd_protocol_info,
            "test": cmd_protocol_test,
            "detect": cmd_protocol_detect,
            "send": cmd_protocol_send,
            "stats": cmd_protocol_stats,
            "transform": cmd_protocol_transform,
            "capabilities": cmd_protocol_capabilities,
        },
        "config": {
            "get": cmd_config_get,
            "set": cmd_config_set,
        },
        "dev": {
            "doctor": cmd_dev_doctor,
        },
        "db": {
            "migrate": cmd_db_migrate,
            "migrate-status": cmd_db_migrate_status,
            "migrate-rollback": cmd_db_migrate_rollback,
            "backup": cmd_db_backup,
        },
        "version": lambda a: cmd_version(a),
        "status": lambda a: cmd_status(a),
    }

    handler = cmd_map.get(args.command)
    if handler:
        if isinstance(handler, dict):
            subcmd = getattr(args, "subcommand", None)
            if subcmd and subcmd in handler:
                return handler[subcmd](args)
            else:
                print_info(f"Available subcommands: {', '.join(handler.keys())}")
                return 0
        else:
            return handler(args)
    else:
        parser.print_help()
        return 0


if __name__ == "__main__":
    sys.exit(main() or 0)
