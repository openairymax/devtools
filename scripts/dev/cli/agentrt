def cmd_status(args):
    print_header("AgentOS System Status")

    result = api_request("GET", "/health")
    if "error" in result:
        print_error(f"Gateway unreachable: {result['error']}")
        print_info(f"Expected at: {GATEWAY_URL}")
        return 1

    print_success(f"Gateway: {result.get('status', 'unknown')} (v{result.get('version', '?')})")

    services = result.get("services", {})
    if isinstance(services, dict):
        for name, info in services.items():
            if isinstance(info, dict):
                status = "healthy" if info.get("healthy") else "unhealthy"
                symbol = "✓" if info.get("healthy") else "✗"
                print(f"  {symbol} {name}: {status}")

    return 0


def cmd_dev_doctor(args):
    print_header("AgentOS Diagnostics")
    errors = 0

    import shutil

    tools = [
        ("cmake", "CMake", True),
        ("gcc", "C Compiler (GCC)", True),
        ("g++", "C++ Compiler (G++)", True),
        ("python3", "Python 3", True),
        ("docker", "Docker", False),
        ("node", "Node.js", False),
        ("cargo", "Rust/Cargo", False),
    ]

    print(f"{'Tool':<25} {'Status':<10}")
    print("-" * 35)
    for cmd, name, required in tools:
        path = shutil.which(cmd)
        if path:
            print_success(f"{name:<25} Found")
        elif required:
            print_error(f"{name:<25} Missing (required)")
            errors += 1
        else:
            print_warning(f"{name:<25} Not found (optional)")

    gateway_ok = False
    try:
        import urllib.request
        urllib.request.urlopen(f"{GATEWAY_URL}/health", timeout=3)
        gateway_ok = True
    except Exception:
        pass

    if gateway_ok:
        print_success(f"{'Gateway':<25} Running ({GATEWAY_URL})")
    else:
        print_warning(f"{'Gateway':<25} Not running")

    if errors > 0:
        print_error(f"\n{errors} required tool(s) missing")
        return 1
    else:
        print_success("\nAll required tools available")
        return 0


