BLUE = "\033[34m"
CYAN = "\033[36m"
RESET = "\033[0m"

GATEWAY_URL = os.environ.get("AGENTOS_ENDPOINT", "http://localhost:18789")
API_KEY = os.environ.get("AGENTOS_API_KEY", "")


def print_header(text: str):
    print(f"\n{BOLD}{BLUE}{'=' * 60}{RESET}")
    print(f"{BOLD}{BLUE}  {text}{RESET}")
    print(f"{BOLD}{BLUE}{'=' * 60}{RESET}\n")


def print_success(text: str):
    print(f"{GREEN}✓{RESET} {text}")


def print_error(text: str):
    print(f"{RED}✗{RESET} {text}")


def print_warning(text: str):
    print(f"{YELLOW}⚠{RESET} {text}")


def print_info(text: str):
    print(f"{CYAN}→{RESET} {text}")


def api_request(method: str, path: str, data: Optional[Dict] = None) -> Dict:
    import urllib.request
    import urllib.error

    url = f"{GATEWAY_URL}{path}"
    headers = {"Content-Type": "application/json"}
    if API_KEY:
        headers["Authorization"] = f"Bearer {API_KEY}"

    body = json.dumps(data).encode() if data else None
    req = urllib.request.Request(url, data=body, headers=headers, method=method)

    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            return json.loads(resp.read().decode())
    except urllib.error.HTTPError as e:
        return {"error": f"HTTP {e.code}: {e.reason}"}
    except urllib.error.URLError as e:
        return {"error": f"Connection failed: {e.reason}"}
    except Exception as e:
        return {"error": str(e)}


def jsonrpc_request(method: str, params: Optional[Dict] = None) -> Dict:
    import uuid
    return api_request("POST", "/jsonrpc", {
        "jsonrpc": "2.0",
        "id": str(uuid.uuid4()),
        "method": method,
        "params": params or {}
    })


def cmd_service_list(args):
    print_header("AgentOS Services")
    result = jsonrpc_request("service.list")
    if "error" in result:
        print_error(f"Failed to list services: {result['error']}")
        return 1

    services = result.get("result", {}).get("services", [])
    if not services:
        print_info("No services found")
        return 0

    print(f"{'Name':<20} {'Status':<12} {'Healthy':<10} {'Port':<8}")
    print("-" * 50)
    for svc in services:
        status = svc.get("status", "unknown")
        healthy = "✓" if svc.get("healthy") else "✗"
        port = svc.get("port", "-")
        name = svc.get("name", "-")
        print(f"{name:<20} {status:<12} {healthy:<10} {port:<8}")

    return 0


def cmd_service_health(args):
    print_header("AgentOS Health Check")
    result = api_request("GET", "/health")
    if "error" in result:
        print_error(f"Health check failed: {result['error']}")
        return 1

    status = result.get("status", "unknown")
    version = result.get("version", "unknown")
    uptime = result.get("uptime_seconds", 0)

    if status == "ok" or status == "healthy":
        print_success(f"Gateway is healthy (v{version}, uptime: {uptime}s)")
    else:
        print_warning(f"Gateway status: {status}")

    return 0


